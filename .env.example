# Environment Variables Template
# Copy this file to .env and fill in your values

# Serial Port Configuration
COM_PORT=COM1
BAUDRATE=9600

# PLC Configuration
PLC_HOST=172.16.100.100
PLC_PORT=1025

# NAS Server Configuration (No spaces around =)
NAS_IP=172.16.100.183
NAS_USERNAME=your_username
NAS_PASSWORD=your_password
NAS_SHARE_FOLDER=MMKI

# Application Settings
APP_ENV=production
LOG_LEVEL=INFO
